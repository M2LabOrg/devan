{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DEVAN Agent",
  "version": "0.1.8",
  "identifier": "io.m2lab.devan",
  "build": {
    "beforeDevCommand": "bash sync_templates.sh",
    "beforeBuildCommand": "bash sync_templates.sh",
    "frontendDist": "ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DEVAN Agent",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "index.html",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../client/app.py",
      "../client/config.json",
      "../client/requirements.txt",
      "../client/start.sh",
      "../client/templates/**/*"
    ]
  }
}
