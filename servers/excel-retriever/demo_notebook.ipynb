   "source": [
    "import os\\n",
    "\\n",
    "# Create the mcp_project directory\\n",
    "os.makedirs('mcp_project', exist_ok=True)\\n",
    "\\n",
    "print(\\"✓ Created mcp_project/ folder\\")\\n",
    "print(\\"\\nThis folder will contain the MCP server files.\\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\\n",
    "\\n",
    "## Step 3: Generate the MCP Server Files\\n",
    "\\n",
    "The following cells use the `%%writefile` magic function to create the server files.\\n",
    "\\n",
    "**Important:** These cells save the file content but do NOT execute the server code.\\n",
    "\\n",
    "### 3a. Create excel_server.py"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "%%writefile mcp_project/excel_server.py\\n",
    "\\n",
    "\\"\\"\\"\\n",
    "MCP Server for Excel Data Extraction using Docling\\n",
    "\\n",
    "This server provides tools to extract and query data from Excel files.\\n",
    "It uses docling for robust document understanding and extraction.\\n",
    "\\"\\"\\"\\n",
    "\\n",
    "import json\\n",
    "import os\\n",
    "from pathlib import Path\\n",
    "from typing import List, Dict, Any, Optional\\n",
    "from datetime import datetime\\n",
    "from mcp.server.fastmcp import FastMCP\\n",
    "\\n",
    "# Docling imports for Excel processing\\n",
    "try:\\n",
    "    from docling.document_converter import DocumentConverter\\n",
    "    from docling.datamodel.base_models import InputFormat\\n",
    "    from docling.datamodel.document import ConversionResult\\n",
    "    DOCLING_AVAILABLE = True\\n",
    "except ImportError:\\n",
    "    DOCLING_AVAILABLE = False\\n",
    "    print(\\"Warning: docling not installed. Excel extraction will be limited.\\")\\n",
    "\\n",
    "\\n",
    "# Default directory for Excel files (relative to mcp_project/)\\n",
    "EXCEL_DIR = os.environ.get(\\"EXCEL_DIR\\", \\"../excel_files\\")\\n",
    "\\n",
    "# Initialize FastMCP server\\n",
    "mcp = FastMCP(\\"excel-retriever\\")\\n",
    "\\n",
    "# Initialize docling converter\\n",
    "_converter: Optional[DocumentConverter] = None\\n",
    "\\n",
    "def get_converter() -> DocumentConverter:\\n",
    "    \\"\\"\\"Get or create the DocumentConverter instance.\\"\\"\\"\\n",
    "    global _converter\\n",
    "    if _converter is None:\\n",
    "        _converter = DocumentConverter()\\n",
    "    return _converter\\n",
    "\\n",
    "\\n",
    "@mcp.tool()\\n",
    "def list_excel_files(directory: Optional[str] = None) -> str:\\n",
    "    \\"\\"\\"\\n",
    "    List all Excel files (.xlsx, .xls) in the specified directory.\\n",
    "    \\
",
    "    Args:\\n",
    "        directory: Path to directory containing Excel files. \\\n",
    "                    Defaults to EXCEL_DIR environment variable or '../excel_files'.\\n",
    "        \\
",
    "    Returns:\\n",
    "        JSON string with list of Excel files and their metadata.\\n",
    "    \\"\\"\\"\\n",
    "    search_dir = directory or EXCEL_DIR\\n",
    "    \\
",
    "    if not os.path.exists(search_dir):\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"Directory not found: {search_dir}\\",\\n",
    "            \\"hint\\": \\"Create the directory or set EXCEL_DIR environment variable\\"\\n",
    "        }, indent=2)\\n",
    "    \\
",
    "    excel_extensions = ['.xlsx', '.xls', '.xlsm', '.xlsb']\\n",
    "    files = []\\n",
    "    \\
",
    "    for item in os.listdir(search_dir):\\n",
    "        if any(item.lower().endswith(ext) for ext in excel_extensions):\\n",
    "            file_path = os.path.join(search_dir, item)\\n",
    "            try:\\n",
    "                stat = os.stat(file_path)\\n",
    "                files.append({\\n",
    "                    \\"filename\\": item,\\n",
    "                    \\"path\\": file_path,\\n",
    "                    \\"size_bytes\\": stat.st_size,\\n",
    "                    \\"modified\\": str(stat.st_mtime)\\n",
    "                })\\n",
    "            except OSError as e:\\n",
    "                files.append({\\n",
    "                    \\"filename\\": item,\\n",
    "                    \\"path\\": file_path,\\n",
    "                    \\"error\\": str(e)\\n",
    "                })\\n",
    "    \\
",
    "    return json.dumps({\\n",
    "        \\"directory\\": search_dir,\\n",
    "        \\"file_count\\": len(files),\\n",
    "        \\"files\\": files\\n",
    "    }, indent=2)\\n",
    "\\n",
    "\\n",
    "@mcp.tool()\\n",
    "def extract_excel_content(file_path: str, sheet_name: Optional[str] = None) -> str:\\n",
    "    \\"\\"\\"\\n",
    "    Extract content from an Excel file using docling.\\n",
    "    \\
",
    "    Args:\\n",
    "        file_path: Path to the Excel file\\n",
    "        sheet_name: Optional specific sheet to extract. If not provided,\\n",
    "                   extracts all sheets.\\n",
    "        \\
",
    "    Returns:\\n",
    "        JSON string with extracted content structured as tables and text.\\n",
    "    \\"\\"\\"\\n",
    "    if not DOCLING_AVAILABLE:\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": \\"docling is not installed. Install with: uv add docling\\"\\n",
    "        }, indent=2)\\n",
    "    \\
",
    "    if not os.path.exists(file_path):\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"File not found: {file_path}\\"\\n",
    "        }, indent=2)\\n",
    "    \\
",
    "    try:\\n",
    "        converter = get_converter()\\n",
    "        result = converter.convert(file_path)\\n",
    "        \\
",
    "        # Extract structured content\\n",
    "        extracted_data = {\\n",
    "            \\"file_path\\": file_path,\\n",
    "            \\"file_name\\": os.path.basename(file_path),\\n",
    "            \\"document_type\\": \\"excel\\",\\n",
    "            \\"pages\\": []\\n",
    "        }\\n",
    "        \\
",
    "        # Process each page (sheet in Excel context)\\n",
    "        for page in result.pages:\\n",
    "            page_data = {\\n",
    "                \\"page_number\\": page.page_no,\\n",
    "                \\"tables\\": [],\\n",
    "                \\"text_content\\": \\"\\"\\n",
    "            }\\n",
    "            \\
",
    "            # Extract tables\\n",
    "            for table in page.tables:\\n",
    "                table_data = {\\n",
    "                    \\"headers\\": table.header if hasattr(table, 'header') else [],\\n",
    "                    \\"rows\\": []\\n",
    "                }\\n",
    "                \\
",
    "                # Process table rows\\n",
    "                for row in table.data:\\n",
    "                    row_data = []\\n",
    "                    for cell in row:\\n",
    "                        cell_text = str(cell) if cell else \\"\\"\\n",
    "                        row_data.append(cell_text)\\n",
    "                    table_data[\\"rows\\"].append(row_data)\\n",
    "                \\
",
    "                page_data[\\"tables\\"].append(table_data)\\n",
    "            \\
",
    "            # Extract text content\\n",
    "            for item in page.items:\\n",
    "                if hasattr(item, 'text'):\\n",
    "                    page_data[\\"text_content\\"] += item.text + \\"\\n\\"\\n",
    "            \\
",
    "            extracted_data[\\"pages\\"].append(page_data)\\n",
    "        \\
",
    "        # Also get the full text export\\n",
    "        extracted_data[\\"full_text\\"] = result.document.export_to_text()\\n",
    "        extracted_data[\\"markdown\\"] = result.document.export_to_markdown()\\n",
    "        \\
",
    "        return json.dumps(extracted_data, indent=2, default=str)\\n",
    "        \\
",
    "    except Exception as e:\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"Failed to extract content: {str(e)}\\",\\n",
    "            \\"file_path\\": file_path\\n",
    "        }, indent=2)\\n",
    "\\n",
    "\\n",
    "@mcp.tool()\\n",
    "def query_excel_data(file_path: str, query: str) -> str:\\n",
    "    \\"\\"\\"\\n",
    "    Query specific information from an Excel file.\\n",
    "    This extracts the content and returns structured data that can be\\n",
    "    further processed by the LLM.\\n",
    "    \\
",
    "    Args:\\n",
    "        file_path: Path to the Excel file\\n",
    "        query: Description of what data to look for (e.g., \\"sales figures\\", \\\n",
    "               \\"employee names\\", \\"Q1 revenue\\")\\n",
    "        \\
",
    "    Returns:\\n",
    "        JSON string with relevant extracted data based on the query context.\\n",
    "    \\"\\"\\"\\n",
    "    if not DOCLING_AVAILABLE:\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": \\"docling is not installed. Install with: uv add docling\\"\\n",
    "        }, indent=2)\\n",
    "    \\
",
    "    if not os.path.exists(file_path):\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"File not found: {file_path}\\"\\n",
    "        }, indent=2)\\n",
    "    \\
",
    "    try:\\n",
    "        # First extract all content\\n",
    "        converter = get_converter()\\n",
    "        result = converter.convert(file_path)\\n",
    "        \\
",
    "        # Get structured data\\n",
    "        structured_data = {\\n",
    "            \\"query\\": query,\\n",
    "            \\"file\\": os.path.basename(file_path),\\n",
    "            \\"sheets\\": [],\\n",
    "            \\"tables\\": [],\\n",
    "            \\"key_values\\": []\\n",
    "        }\\n",
    "        \\
",
    "        # Process all pages/sheets\\n",
    "        for page in result.pages:\\n",
    "            sheet_info = {\\n",
    "                \\"sheet_number\\": page.page_no,\\n",
    "                \\"tables_found\\": len(page.tables),\\n",
    "                \\"text_segments\\": []\\n",
    "            }\\n",
    "            \\
",
    "            # Extract text segments\\n",
    "            for item in page.items:\\n",
    "                if hasattr(item, 'text'):\\n",
    "                    sheet_info[\\"text_segments\\"].append(item.text)\\n",
    "            \\
",
    "            structured_data[\\"sheets\\"].append(sheet_info)\\n",
    "            \\
",
    "            # Extract all tables\\n",
    "            for table in page.tables:\\n",
    "                table_rows = []\\n",
    "                for row in table.data:\\n",
    "                    row_cells = [str(cell) if cell else \\"\\" for cell in row]\\n",
    "                    table_rows.append(row_cells)\\n",
    "                \\
",
    "                structured_data[\\"tables\\"].append({\\n",
    "                    \\"sheet\\": page.page_no,\\n",
    "                    \\"row_count\\": len(table_rows),\\n",
    "                    \\"data\\": table_rows[:50]  # Limit to first 50 rows\\n",
    "                })\\n",
    "        \\
",
    "        # Get full markdown for context\\n",
    "        structured_data[\\"full_content_preview\\"] = result.document.export_to_markdown()[:5000]\\n",
    "        \\
",
    "        return json.dumps(structured_data, indent=2, default=str)\\n",
    "        \\
",
    "    except Exception as e:\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"Failed to query data: {str(e)}\\",\\n",
    "            \\"file_path\\": file_path,\\n",
    "            \\"query\\": query\\n",
    "        }, indent=2)\\n",
    "\\n",
    "\\n",
    "@mcp.tool()\\n",
    "def get_excel_summary(file_path: str) -> str:\\n",
    "    \\"\\"\\"\\n",
    "    Get a summary of an Excel file's structure and content.\\n",
    "    \\
",
    "    Args:\\n",
    "        file_path: Path to the Excel file\\n",
    "        \\
",
    "    Returns:\\n",
    "        JSON string with summary information about sheets, tables, and data.\\n",
    "    \\"\\"\\"\\n",
    "    if not DOCLING_AVAILABLE:\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": \\"docling is not installed. Install with: uv add docling\\"\\n",
    "        }, indent=2)\\n",
    "    \\
",
    "    if not os.path.exists(file_path):\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"File not found: {file_path}\\"\\n",
    "        }, indent=2)\\n",
    "    \\
",
    "    try:\\n",
    "        converter = get_converter()\\n",
    "        result = converter.convert(file_path)\\n",
    "        \\
",
    "        summary = {\\n",
    "            \\"file_name\\": os.path.basename(file_path),\\n",
    "            \\"file_path\\": file_path,\\n",
    "            \\"total_sheets\\": len(result.pages),\\n",
    "            \\"sheets\\": []\\n",
    "        }\\n",
    "        \\
",
    "        for page in result.pages:\\n",
    "            sheet_summary = {\\n",
    "                \\"sheet_number\\": page.page_no,\\n",
    "                \\"table_count\\": len(page.tables),\\n",
    "                \\"has_text\\": len(page.items) > 0,\\n",
    "                \\"tables\\": []\\n",
    "            }\\n",
    "            \\
",
    "            for i, table in enumerate(page.tables):\\n",
    "                row_count = len(table.data) if hasattr(table, 'data') else 0\\n",
    "                sheet_summary[\\"tables\\"].append({\\n",
    "                    \\"table_index\\": i,\\n",
    "                    \\"row_count\\": row_count\\n",
    "                })\\n",
    "            \\
",
    "            summary[\\"sheets\\"].append(sheet_summary)\\n",
    "        \\
",
    "        return json.dumps(summary, indent=2, default=str)\\n",
    "        \\
",
    "    except Exception as e:\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"Failed to generate summary: {str(e)}\\",\\n",
    "            \\"file_path\\": file_path\\n",
    "        }, indent=2)\\n",
    "\\n",
    "\\n",
    "@mcp.tool()\\n",
    "def convert_excel_to_csv(file_path: str, output_dir: Optional[str] = None) -> str:\\n",
    "    \\"\\"\\"\\n",
    "    Convert Excel file sheets to CSV format.\\n",
    "    \\
",
    "    Args:\\n",
    "        file_path: Path to the Excel file\\n",
    "        output_dir: Optional directory to save CSV files. Defaults to same directory as Excel file.\\n",
    "        \\
",
    "    Returns:\\n",
    "        JSON string with paths to created CSV files.\\n",
    "    \\"\\"\\"\\n",
    "    if not os.path.exists(file_path):\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"File not found: {file_path}\\"\\n",
    "        }, indent=2)\\n",
    "    \\
",
    "    try:\\n",
    "        import pandas as pd\\n",
    "        \\
",
    "        # Determine output directory\\n",
    "        if output_dir is None:\\n",
    "            output_dir = os.path.dirname(file_path) or \\".\\"\\n",
    "        \\
",
    "        os.makedirs(output_dir, exist_ok=True)\\n",
    "        \\
",
    "        # Read all sheets\\n",
    "        excel_file = pd.ExcelFile(file_path)\\n",
    "        created_files = []\\n",
    "        \\
",
    "        base_name = Path(file_path).stem\\n",
    "        \\
",
    "        for sheet_name in excel_file.sheet_names:\\n",
    "            df = pd.read_excel(file_path, sheet_name=sheet_name)\\n",
    "            \\
",
    "            # Create safe filename\\n",
    "            safe_sheet = \\"\\".join(c if c.isalnum() else \\"_\\" for c in sheet_name)\\n",
    "            csv_filename = f\\"{base_name}_{safe_sheet}.csv\\"\\n",
    "            csv_path = os.path.join(output_dir, csv_filename)\\n",
    "            \\
",
    "            df.to_csv(csv_path, index=False)\\n",
    "            created_files.append({\\n",
    "                \\"sheet_name\\": sheet_name,\\n",
    "                \\"csv_path\\": csv_path,\\n",
    "                \\"rows\\": len(df),\\n",
    "                \\"columns\\": len(df.columns)\\n",
    "            })\\n",
    "        \\
",
    "        return json.dumps({\\n",
    "            \\"source_file\\": file_path,\\n",
    "            \\"output_directory\\": output_dir,\\n",
    "            \\"csv_files_created\\": len(created_files),\\n",
    "            \\"files\\": created_files\\n",
    "        }, indent=2)\\n",
    "        \\
",
    "    except ImportError:\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": \\"pandas not installed. Install with: uv add pandas\\"\\n",
    "        }, indent=2)\\n",
    "    except Exception as e:\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"Failed to convert to CSV: {str(e)}\\",\\n",
    "            \\"file_path\\": file_path\\n",
    "        }, indent=2)\\n",
    "\\n",
    "\\n",
    "@mcp.tool()\\n",
    "def convert_excel_to_json(file_path: str, output_dir: Optional[str] = None, include_metadata: bool = True) -> str:\\n",
    "    \\"\\"\\"\\n",
    "    Convert Excel file sheets to JSON format.\\n",
    "    \\
",
    "    Args:\\n",
    "        file_path: Path to the Excel file\\n",
    "        output_dir: Optional directory to save JSON files. Defaults to same directory as Excel file.\\n",
    "        include_metadata: Whether to include sheet metadata (default: True)\\n",
    "        \\
",
    "    Returns:\\n",
    "        JSON string with paths to created JSON files and inline data preview.\\n",
    "    \\"\\"\\"\\n",
    "    if not os.path.exists(file_path):\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"File not found: {file_path}\\"\\n",
    "        }, indent=2)\\n",
    "    \\
",
    "    try:\\n",
    "        import pandas as pd\\n",
    "        \\
",
    "        # Determine output directory\\n",
    "        if output_dir is None:\\n",
    "            output_dir = os.path.dirname(file_path) or \\".\\"\\n",
    "        \\
",
    "        os.makedirs(output_dir, exist_ok=True)\\n",
    "        \\
",
    "        # Read all sheets\\n",
    "        excel_file = pd.ExcelFile(file_path)\\n",
    "        created_files = []\\n",
    "        all_data = {}\\n",
    "        \\
",
    "        base_name = Path(file_path).stem\\n",
    "        \\
",
    "        for sheet_name in excel_file.sheet_names:\\n",
    "            df = pd.read_excel(file_path, sheet_name=sheet_name)\\n",
    "            \\
",
    "            # Convert to records (list of dicts)\\n",
    "            records = df.replace({pd.NaT: None, pd.NA: None}).to_dict(orient='records')\\n",
    "            \\
",
    "            # Clean NaN values for JSON serialization\\n",
    "            clean_records = []\\n",
    "            for record in records:\\n",
    "                clean_record = {}\\n",
    "                for key, value in record.items():\\n",
    "                    if pd.isna(value):\\n",
    "                        clean_record[key] = None\\n",
    "                    elif isinstance(value, (pd.Timestamp, datetime)):\\n",
    "                        clean_record[key] = value.isoformat()\\n",
    "                    else:\\n",
    "                        clean_record[key] = value\\n",
    "                clean_records.append(clean_record)\\n",
    "            \\
",
    "            # Create JSON data structure\\n",
    "            sheet_data = {\\n",
    "                \\"sheet_name\\": sheet_name,\\n",
    "                \\"row_count\\": len(df),\\n",
    "                \\"column_count\\": len(df.columns),\\n",
    "                \\"columns\\": list(df.columns),\\n",
    "                \\"data\\": clean_records\\n",
    "            }\\n",
    "            \\
",
    "            if include_metadata:\\n",
    "                sheet_data[\\"metadata\\"] = {\\n",
    "                    \\"source_file\\": os.path.basename(file_path),\\n",
    "                    \\"sheet_index\\": excel_file.sheet_names.index(sheet_name),\\n",
    "                    \\"dtypes\\": {col: str(df[col].dtype) for col in df.columns}\\n",
    "                }\\n",
    "            \\
",
    "            all_data[sheet_name] = sheet_data\\n",
    "            \\
",
    "            # Create safe filename\\n",
    "            safe_sheet = \\"\\".join(c if c.isalnum() else \\"_\\" for c in sheet_name)\\n",
    "            json_filename = f\\"{base_name}_{safe_sheet}.json\\"\\n",
    "            json_path = os.path.join(output_dir, json_filename)\\n",
    "            \\
",
    "            # Write individual sheet JSON\\n",
    "            with open(json_path, 'w', encoding='utf-8') as f:\\n",
    "                json.dump(sheet_data, f, indent=2, ensure_ascii=False, default=str)\\n",
    "            \\
",
    "            created_files.append({\\n",
    "                \\"sheet_name\\": sheet_name,\\n",
    "                \\"json_path\\": json_path,\\n",
    "                \\"rows\\": len(df),\\n",
    "                \\"columns\\": len(df.columns)\\n",
    "            })\\n",
    "        \\
",
    "        # Also create a combined JSON file with all sheets\\n",
    "        combined_filename = f\\"{base_name}_all_sheets.json\\"\\n",
    "        combined_path = os.path.join(output_dir, combined_filename)\\n",
    "        \\
",
    "        combined_data = {\\n",
    "            \\"source_file\\": os.path.basename(file_path),\\n",
    "            \\"file_path\\": file_path,\\n",
    "            \\"total_sheets\\": len(excel_file.sheet_names),\\n",
    "            \\"sheet_names\\": excel_file.sheet_names,\\n",
    "            \\"sheets\\": all_data\\n",
    "        }\\n",
    "        \\
",
    "        with open(combined_path, 'w', encoding='utf-8') as f:\\n",
    "            json.dump(combined_data, f, indent=2, ensure_ascii=False, default=str)\\n",
    "        \\
",
    "        return json.dumps({\\n",
    "            \\"source_file\\": file_path,\\n",
    "            \\"output_directory\\": output_dir,\\n",
    "            \\"json_files_created\\": len(created_files),\\n",
    "            \\"files\\": created_files,\\n",
    "            \\"combined_file\\": combined_path,\\n",
    "            \\"preview\\": {\\n",
    "                sheet: {\\n",
    "                    \\"columns\\": data[\\"columns\\"],\\n",
    "                    \\"row_count\\": data[\\"row_count\\"],\\n",
    "                    \\"sample_rows\\": data[\\"data\\"][:3] if data[\\"data\\"] else []\\n",
    "                }\\n",
    "                for sheet, data in all_data.items()\\n",
    "            }\\n",
    "        }, indent=2, default=str)\\n",
    "        \\
",
    "    except ImportError:\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": \\"pandas not installed. Install with: uv add pandas\\"\\n",
    "        }, indent=2)\\n",
    "    except Exception as e:\\n",
    "        return json.dumps({\\n",
    "            \\"error\\": f\\"Failed to convert to JSON: {str(e)}\\",\\n",
    "            \\"file_path\\": file_path\\n",
    "        }, indent=2)\\n",
    "\\n",
    "\\n",
    "if __name__ == \\"__main__\\":\\n",
    "    # Initialize and run the server\\n",
    "    mcp.run(transport='stdio')\\n"
   ]
  },
