   "source": [
    "# Create sample Excel file for demonstration\\n",
    "import pandas as pd\\n",
    "import os\\n",
    "\\n",
    "# Create excel_files directory at the root level\\n",
    "os.makedirs('excel_files', exist_ok=True)\\n",
    "\\n",
    "# Sample structured data - Project costs\\n",
    "project_data = {\\n",
    "    'Project_ID': ['PRJ-001', 'PRJ-002', 'PRJ-003', 'PRJ-004', 'PRJ-005'],\\n",
    "    'Project_Name': ['Offshore Platform A', 'Wind Farm B', 'Pipeline C', 'Refinery D', 'Subsea E'],\\n",
    "    'Region': ['North Sea', 'Baltic Sea', 'Gulf of Mexico', 'Middle East', 'Norwegian Sea'],\\n",
    "    'Budget_MUSD': [450.5, 280.3, 125.8, 890.2, 340.7],\\n",
    "    'Actual_Cost_MUSD': [445.2, 295.1, 118.5, 920.5, 338.9],\\n",
    "    'Status': ['Complete', 'In Progress', 'Complete', 'In Progress', 'Planning'],\\n",
    "    'Risk_Level': ['Low', 'Medium', 'Low', 'High', 'Medium']\\n",
    "}\\n",
    "\\n",
    "# Create Excel file with multiple sheets\\n",
    "with pd.ExcelWriter('excel_files/sample_projects.xlsx') as writer:\\n",
    "    # Main projects sheet\\n",
    "    pd.DataFrame(project_data).to_excel(writer, sheet_name='Projects', index=False)\\n",
    "    \\n",
    "    # Summary sheet\\n",
    "    summary_data = {\\n",
    "        'Metric': ['Total Projects', 'Total Budget', 'Total Actual Cost', 'Avg Budget per Project'],\\n",
    "        'Value': [5, '2087.5 MUSD', '2118.2 MUSD', '417.5 MUSD']\\n",
    "    }\\n",
    "    pd.DataFrame(summary_data).to_excel(writer, sheet_name='Summary', index=False)\\n",
    "    \\n",
    "    # Risk analysis sheet\\n",
    "    risk_data = {\\n",
    "        'Risk_Level': ['Low', 'Medium', 'High'],\\n",
    "        'Count': [2, 2, 1],\\n",
    "        'Total_Budget': [576.3, 621.0, 890.2]\\n",
    "    }\\n",
    "    pd.DataFrame(risk_data).to_excel(writer, sheet_name='Risk_Analysis', index=False)\\n",
    "\\n",
    "print(\\"✓ Sample Excel file created: excel_files/sample_projects.xlsx\\")\\n",
    "print(\\"\\nFile contains 3 sheets:\\")\\n",
    "print(\\"  - Projects: Project details with budget and status\\")\\n",
    "print(\\"  - Summary: Aggregated metrics\\")\\n",
    "print(\\"  - Risk_Analysis: Risk distribution\\")"
